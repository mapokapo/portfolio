---
import "@/styles/globals.css";
import VercelAnalytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

import { getDefaultOgImageUrl } from "@/assets/meta";

type Props = {
  description?: string;
  image?: string;
  keywords?: string[];
  title?: string;
};

const siteUrl = "https://leopetrovic.vercel.app";
const {
  description = "Leo's personal portfolio website",
  image: imageProp,
  keywords = [],
  title = "Home",
} = Astro.props;
const image = imageProp ?? (await getDefaultOgImageUrl());
const fullTitle = `${title} | Leo's Portfolio`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content="#2563eb" name="theme-color" />
    <meta content={description} name="description" />
    {keywords.length > 0 && <meta content={keywords.join(", ")} name="keywords" />}
    <meta
      content="9_qEiY98Q8uHDB5H293-c3ixYEp9bDIEwqcfjvEJbPU"
      name="google-site-verification"
    />
    <link href={canonicalUrl} rel="canonical" />
    <link href="/manifest.json" rel="manifest" />
    <link href="/favicon.ico" rel="icon" sizes="16x16" />
    <link
      href="/icons/icon-96x96.png"
      rel="icon"
      sizes="96x96"
      type="image/png"
    />
    <link
      href="/icons/icon-192x192.png"
      rel="icon"
      sizes="192x192"
      type="image/png"
    />
    {
      ["72", "144", "152"].map(size => (
        <link
          href={`/icons/icon-${size}x${size}.png`}
          rel="apple-touch-icon"
          sizes={`${size}x${size}`}
        />
      ))
    }
    <meta content={description} property="og:description" />
    <meta content={imageUrl} property="og:image" />
    <meta content="Leo's Portfolio" property="og:image:alt" />
    <meta content="Leo's Portfolio" property="og:site_name" />
    <meta content={fullTitle} property="og:title" />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={description} name="twitter:description" />
    <meta content={imageUrl} name="twitter:image" />
    <meta content={fullTitle} name="twitter:title" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />
    <VercelAnalytics />
    <SpeedInsights />
    <script is:inline>
      const schedulePageView =
        window.requestIdleCallback ?? ((callback) => window.setTimeout(callback, 1));

      schedulePageView(() => {
        fetch("/api/pageView", {
          headers: { "Content-Type": "application/json" },
          method: "POST",
        }).catch(() => {});
      });

      (() => {
        const scrollKey = "scroll-position:/";
        const isIndex =
          location.pathname === "/" || location.pathname === "";

        if (!isIndex) {
          return;
        }

        addEventListener(
          "pagehide",
          () => {
            sessionStorage.setItem(scrollKey, String(scrollY));
          },
          { capture: true }
        );

        const saved = sessionStorage.getItem(scrollKey);
        if (saved === null) {
          return;
        }

        const navigation = performance.getEntriesByType("navigation")[0];
        const shouldRestore =
          navigation?.type === "back_forward" ||
          (document.referrer !== "" &&
            new URL(document.referrer).origin === location.origin);

        if (!shouldRestore) {
          return;
        }

        const restore = () => {
          scrollTo({ top: Number(saved), behavior: "instant" });
        };

        if (document.readyState === "complete") {
          requestAnimationFrame(() => requestAnimationFrame(restore));
        } else {
          addEventListener("load", () => requestAnimationFrame(restore), {
            once: true,
          });
        }
      })();
    </script>
  </body>
</html>
