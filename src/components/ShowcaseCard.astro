---
import { MdExpandMore, MdLaunch } from "react-icons/md";

import type Showcase from "@/lib/types/Showcase";

import ShowcaseImage from "@/assets/showcase/ShowcaseImage.astro";
import Icon from "@/components/Icon";

type Props = {
  showcase: Showcase;
};

const { showcase } = Astro.props;
---

<details
  class="details-expand group relative flex h-min w-full min-w-75 flex-col bg-slate-800 shadow-md shadow-slate-800 transition-all hover:brightness-125 sm:w-min sm:min-w-100 open:sm:min-w-150">
  <summary
    class="flex h-full w-full cursor-pointer list-none flex-col justify-between px-4 pt-8 pb-4 select-none [&::-webkit-details-marker]:hidden">
    <div class="mx-auto mb-2 flex h-16 items-center justify-center">
      <ShowcaseImage
        alt={`Image of project called ${showcase.title}`}
        class="h-16 w-16 object-contain opacity-90"
        imageKey={showcase.meta.imageKey}
        width={64}
      />
    </div>
    <div class="flex flex-col gap-4">
      <h3 class="mb-auto text-center text-2xl text-white sm:text-4xl">
        {showcase.title}
      </h3>
      <p class="mx-auto flex text-center text-sm text-white sm:text-xl">
        {showcase.description}
      </p>
    </div>
    <MdExpandMore
      aria-hidden="true"
      className="mx-auto mt-2 text-white transition-transform group-open:rotate-180"
      size={24}
    />
  </summary>
  <div class="w-full bg-slate-800 px-4 pb-2">
    <div class="flex flex-col gap-1 p-2 text-white">
      <p class="mx-2 mb-4 text-left text-sm text-gray-300">
        {showcase.content}
      </p>
      <span class="mb-2 text-2xl">Made with</span>
      <ul class="flex list-inside flex-wrap justify-center gap-4">
        {
          showcase.meta.madeWith.map(label => (
            <li class="flex items-center gap-2 rounded-lg border border-gray-700 px-2 text-sm whitespace-nowrap sm:text-lg">
              <Icon name={label} />
              {label}
            </li>
          ))
        }
      </ul>
      {
        showcase.meta.links?.map((link, index) => (
          <a
            class:list={[`mx-auto flex items-center justify-center gap-2 rounded-lg px-4 py-2 hover:bg-slate-700 
              
            `,{"mt-1": index !== 0, "mt-4": index === 0}]}
            href={link.url}
            rel="noreferrer"
            target="_blank">
            <MdLaunch aria-hidden="true" />
            <span>{link.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</details>
