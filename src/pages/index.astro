---
import { FaLinkedin } from "react-icons/fa";
import { MdEast, MdExpandMore } from "react-icons/md";
import { SiGithub } from "react-icons/si";

import type TextData from "@/lib/types/TextData";

import AnchorMenu from "@/components/AnchorMenu";
import QuoteView from "@/components/QuoteView";
import ShowcaseCard from "@/components/ShowcaseCard.astro";
import SiteInfo from "@/components/SiteInfo";
import TechStackTree from "@/components/TechStackTree.astro";
import Typewriter from "@/components/Typewriter";
import BaseLayout from "@/layouts/BaseLayout.astro";
import textDataJson from "@/lib/const/data.json";
import { getSiteInfo } from "@/lib/server/siteInfo";
import { randomChoice } from "@/lib/utils";

export const prerender = true;

const textData = textDataJson as TextData;
const initialQuote = randomChoice(textData.quotes);
const siteInfo = await getSiteInfo();
---

<BaseLayout title="Home">
  <main class="relative flex h-full w-full flex-col bg-slate-900">
    <AnchorMenu
      anchors={[
        { id: "main", label: "Intro" },
        { id: "showcase", label: "Showcase" },
        { id: "tech-stack", label: "Tech stack" },
        { id: "website-info", label: "Website info" },
        { id: "links", label: "Links" },
      ]}
      client:load
    />
    <section
      class="relative flex min-h-screen w-full scroll-mt-28 flex-col items-center justify-center gap-2 bg-linear-to-tr from-blue-600 to-blue-500 pt-[10%]"
      id="main"
      style="background-size: 400% 400%;">
      <QuoteView
        client:load
        initialQuote={initialQuote}
        quotes={textData.quotes}
      />
      <Typewriter client:load />
      <span class="text-lg text-gray-100 sm:text-2xl">
        Welcome to my website
      </span>
      <MdExpandMore
        aria-hidden="true"
        className="mb-auto animate-bounce"
        color="#eee"
        size={36}
      />
      <span class="mb-20 text-lg text-white/50 sm:mt-16 sm:mb-24 sm:text-xl">
        Learn more about me...
      </span>
    </section>
    <section class="relative flex flex-col bg-linear-to-b from-blue-600 to-slate-900 pt-8 pb-16 sm:pb-32">
      <div class="absolute z-0 -mt-8 h-8 w-full bg-linear-to-b from-[rgb(37,99,235)] to-[#235EDD] blur-md sm:-mt-14 sm:h-16">
      </div>
      <section class="flex h-[25vw] min-h-75 flex-col justify-center gap-6 p-4 pb-16 sm:mx-16">
        <h2 class="z-10 text-center text-4xl font-bold text-white sm:text-6xl">
          Intro
        </h2>
        <p class="text-center text-lg text-white sm:text-2xl">
          My name is{" "}
          <span
            class="cursor-default border-b border-dotted border-white"
            title="Pronunciation: Leh-oh Peh-troh-vich">
            Leo Petrović
          </span>
          . I am a {(() => {
            const today = new Date();
            const birthDate = new Date(2003, 6, 22);
            
            let age = today.getFullYear() - birthDate.getFullYear();
            const hasBirthdayPassed = today >= new Date(today.getFullYear(), birthDate.getMonth(), birthDate.getDate());
            
            return hasBirthdayPassed ? age : age - 1;
          })()} year old computer science student, a software developer,
          and technology enthusiast.
        </p>
      </section>
      <a class="mx-auto flex items-end gap-2 text-white" href="/lore">
        <h2 class="z-10 text-center text-xl font-bold underline sm:text-2xl">
          Read more about me
        </h2>
        <MdEast aria-hidden="true" className="mb-0.5" size={24} />
      </a>
    </section>
    <section
      class="mt-24 flex scroll-mt-28 flex-col items-center justify-center gap-4 bg-slate-900"
      id="showcase">
      <h2 class="text-4xl text-white sm:text-7xl">Showcase</h2>
      <span class="px-3 text-center text-lg text-white/75 sm:text-xl">
        Here&apos;s a short list of projects I made so far...
      </span>
      <MdEast aria-hidden="true" className="text-4xl text-gray-400 sm:hidden" />
      <div class="my-2 flex w-full items-stretch gap-4 overflow-x-auto px-4 sm:my-8 sm:w-auto sm:flex-wrap sm:justify-center md:mx-16 lg:mx-[10%]">
        {textData.showcase.map(showcase => <ShowcaseCard showcase={showcase} />)}
      </div>
    </section>
    <section
      class="mt-20 flex scroll-mt-28 flex-col items-center justify-center gap-4 bg-slate-900"
      id="tech-stack">
      <h2 class="text-4xl text-white sm:text-7xl">Tech stack</h2>
      <span class="px-3 text-center text-lg text-white/75 sm:mb-6 sm:text-xl">
        The important part
      </span>
      <ul class="flex flex-col">
        {textData.techStack.map(item => <TechStackTree item={item} root />)}
      </ul>
    </section>
    <SiteInfo client:visible initialInfo={siteInfo} />
    <section
      class="mt-20 flex scroll-mt-28 flex-col items-center justify-center gap-4 bg-slate-900 md:mx-8"
      id="links">
      <h2 class="text-4xl text-white sm:text-7xl">Links</h2>
      <span class="px-3 text-center text-lg text-white/75 sm:text-xl">
        If you want to stay in touch or check out my other projects
      </span>
      <div class="flex justify-between gap-8">
        <a
          aria-label="Github link"
          class="flex h-16 w-16 items-center justify-center rounded-full"
          href="https://github.com/mapokapo"
          rel="noreferrer"
          target="_blank">
          <SiGithub aria-hidden="true" color="#fff" size={32} />
        </a>
        <a
          aria-label="LinkedIn link"
          class="flex h-16 w-16 items-center justify-center rounded-full"
          href="https://www.linkedin.com/in/leo-petrovi%C4%87-7047b1162/"
          rel="noreferrer"
          target="_blank">
          <FaLinkedin aria-hidden="true" color="#fff" size={32} />
        </a>
      </div>
    </section>
    <footer class="my-8 flex items-center justify-center text-white sm:text-base">
      <p>Leo Petrovic • {new Date().getFullYear()}</p>
    </footer>
  </main>
</BaseLayout>
